<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%- name %> | Nexo Bio-Link</title>
    <!-- FontAwesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&family=Playfair+Display:wght@400;700&family=Space+Mono:wght@400;700&display=swap');

        /* Pure Static CSS - Zero IDE Errors */
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            color: var(--text-main, #ffffff);
            overflow-x: hidden;
            background: var(--bg-main, #05070a);
            font-family: var(--font-family, 'Outfit', sans-serif);
        }

        .bg-media {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background-size: cover;
            background-position: center;
            z-index: -2;
            display: none;
        }

        .bg-mesh {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            z-index: -1;
            display: none;
        }

        .container {
            width: 100%;
            max-width: 450px;
            min-height: 100vh;
            background: rgba(0, 0, 0, 0.1);
            backdrop-filter: blur(10px);
            position: relative;
            box-shadow: 0 0 50px rgba(0,0,0,0.3);
        }

        .header {
            height: 260px;
            position: relative;
            background: #111;
            overflow: hidden;
        }

        .mural {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transform: scale(1.1);
            filter: var(--mural-filter, blur(0px));
        }

        .overlay {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: var(--overlay-bg, rgba(0,0,0,0.3));
        }

        .profile-img {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            border: 4px solid var(--accent-color, #00f3ff);
            position: absolute;
            bottom: -60px;
            left: 50%;
            transform: translateX(-50%);
            object-fit: cover;
            z-index: 10;
            background: #1a1a1a;
            box-shadow: 0 10px 30px rgba(0,0,0,0.6);
        }

        .content {
            margin-top: 80px;
            padding: 2rem;
            text-align: center;
        }

        .name {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
            letter-spacing: -0.5px;
        }

        .bio {
            color: var(--text-main);
            opacity: 0.8;
            font-size: 1.05rem;
            line-height: 1.5;
            margin-bottom: 2.5rem;
        }

        .links {
            display: flex;
            flex-direction: column;
            gap: 1.25rem;
        }

        .btn {
            width: 100%;
            padding: 1.1rem;
            text-decoration: none;
            font-weight: 600;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.8rem;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            border-radius: var(--button-radius, 12px);
        }

        .style-solid {
            background: var(--accent-color);
            color: var(--btn-text);
            border: none;
        }

        .style-outline {
            background: transparent;
            border: 2px solid var(--accent-color);
            color: var(--accent-color);
        }

        .style-glass {
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.15);
            color: var(--text-main);
        }

        .finish-glow { box-shadow: 0 0 20px rgba(255,255,255,0.1); }
        .finish-neumorphic { 
            box-shadow: 7px 7px 15px rgba(0,0,0,0.4), -7px -7px 15px rgba(255,255,255,0.05);
            border: none;
        }

        .anim-float:hover { transform: translateY(-6px); }
        .anim-pulse:hover { animation: pulse 1.5s infinite; }
        .anim-glow:hover { box-shadow: 0 0 30px var(--accent-color); }

        @keyframes pulse {
            0% { transform: scale(1); }
            70% { transform: scale(1.04); }
            100% { transform: scale(1); }
        }

        .footer {
            margin-top: 4rem;
            padding-bottom: 2rem;
            font-size: 0.85rem;
            opacity: 0.4;
            text-align: center;
        }

        .footer a {
            color: inherit;
            text-decoration: none;
            font-weight: 700;
        }
    </style>
</head>
<body 
    id="nexo-body"
    data-accent="<%- accentColor %>"
    data-radius="<%- buttonRadius %>"
    data-bg-style="<%- backgroundStyle %>"
    data-text="<%- textColor %>"
    data-btn-text="<%- accentLuminance > 0.5 ? '#000' : '#fff' %>"
    data-font="<%- typography === 'font-modern' ? 'Outfit' : (typography === 'font-elegant' ? 'Playfair Display' : 'Space Mono') %>"
    data-blur="<%- muralBlur %>"
    data-opacity="<%- muralOpacity %>"
    data-bg-mode="<%- bgMode %>"
    data-bg-media="<%- bgMediaBase64 || '' %>"
    data-bg-color2="<%- bgColor2 %>"
>
    <div class="bg-media" id="bg-media"></div>
    <div class="bg-mesh" id="bg-mesh"></div>

    <div class="container">
        <div class="header">
            <% if (muralBase64) { %>
                <img src="<%- muralBase64 %>" class="mural" alt="Mural">
            <% } %>
            <div class="overlay"></div>
            <img src="<%- profileBase64 %>" class="profile-img" alt="<%- name %>">
        </div>

        <div class="content">
            <h1 class="name"><%- name %></h1>
            <p class="bio"><%- bio %></p>

            <div class="links">
                <% links.forEach(function(link) { %>
                    <a href="<%- link.url %>" class="btn <%- buttonFinish %> <%- buttonStyle %> <%- buttonAnimation %>">
                        <i class="<%- link.icon %>"></i> <%- link.title %>
                    </a>
                <% }); %>
            </div>

            <footer class="footer">
                Creado con <a href="#">Nexo Studio</a>
            </footer>
        </div>
    </div>

    <!-- Pure JavaScript - No EJS Tags Inside -> Zero IDE Errors -->
    <script>
        (function() {
            const body = document.getElementById('nexo-body');
            const root = document.documentElement;
            const data = body.dataset;

            // Apply Variables
            root.style.setProperty('--accent-color', data.accent);
            root.style.setProperty('--button-radius', data.radius);
            root.style.setProperty('--bg-main', data.bgStyle);
            root.style.setProperty('--text-main', data.text);
            root.style.setProperty('--btn-text', data.btnText);
            root.style.setProperty('--font-family', data.font + ', sans-serif');
            root.style.setProperty('--mural-filter', 'blur(' + data.blur + 'px)');
            root.style.setProperty('--overlay-bg', 'rgba(0, 0, 0, ' + ((100 - data.opacity) / 100) + ')');

            // Handle Background Modes
            if (data.bgMode === 'media' && data.bgMedia) {
                const bgMedia = document.getElementById('bg-media');
                bgMedia.style.display = 'block';
                bgMedia.style.backgroundImage = 'url(' + data.bgMedia + ')';
            } else if (data.bgMode === 'mesh') {
                const bgMesh = document.getElementById('bg-mesh');
                bgMesh.style.display = 'block';
                bgMesh.style.backgroundImage = 'radial-gradient(at 0% 0%, ' + data.accent + '22 0, transparent 50%), radial-gradient(at 100% 100%, ' + data.bgColor2 + '22 0, transparent 50%)';
            }
        })();
    </script>
</body>
</html>
